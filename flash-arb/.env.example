# ── Deployer wallet ───────────────────────────────────────────────────────────
# NEVER commit the real key. Store in a secrets manager or hardware wallet.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Free public endpoints work for deployment; use Alchemy/QuickNode for production.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Block explorer verification ───────────────────────────────────────────────
# Get free key at https://basescan.org/myapikey
BASESCAN_API_KEY=

# ── Fork testing ──────────────────────────────────────────────────────────────
# Set FORK=1 to enable mainnet fork in hardhat tests.
# Set FORK_BLOCK to pin a block number (deterministic tests).
# FORK=1
# FORK_BLOCK=17000000

# ── Bot config (Python searcher) ──────────────────────────────────────────────
# Same BASE_RPC_URL used by Python bot
# Contract address after deploy:
FLASH_ARB_CONTRACT=
