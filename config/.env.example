# =====================================================================
#  SALIN file ini ke `.env` (TANPA .example) lalu isi nilainya.
#  `.env` SUDAH di-.gitignore. JANGAN pernah commit / screenshot / paste
#  private key Anda ke mana pun, termasuk ke chat AI.
# =====================================================================

# --- Mode operasi: paper | live ---
# DEFAULT WAJIB "paper". Ubah ke "live" HANYA setelah Fase 4 & 5 lolos.
ATLAS_MODE=paper

# --- Wallet (HANYA dibutuhkan saat Fase 1 read-key / Fase 6 live) ---
# Gunakan WALLET KHUSUS BOT dengan dana minimal — BUKAN wallet utama.
# Biarkan KOSONG selama Fase 0–5 (paper trading tidak butuh ini).
ATLAS_PRIVATE_KEY=
ATLAS_WALLET_ADDRESS=

# --- Polymarket CLOB API (Polygon) ---
ATLAS_CLOB_HOST=https://clob.polymarket.com
ATLAS_CHAIN_ID=137

# --- API keys CLOB (digenerate dari wallet saat Fase 1; kosongkan dulu) ---
ATLAS_API_KEY=
ATLAS_API_SECRET=
ATLAS_API_PASSPHRASE=

# --- Notifikasi alert (opsional, read-only — BUKAN copytrade) ---
ATLAS_TELEGRAM_BOT_TOKEN=
ATLAS_TELEGRAM_CHAT_ID=
